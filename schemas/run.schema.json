{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/recoalign/run.schema.json",
  "title": "ReCoAlign run record",
  "type": "object",
  "required": [
    "schema_version", "run_id", "status", "started_at", "config_sha256",
    "dataset", "model", "pretrained", "seed"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["pilot", "partial", "failed", "complete", "reportable"]},
    "started_at": {"type": "string"},
    "completed_at": {"type": ["string", "null"]},
    "config_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "dataset": {"type": "string"},
    "model": {"type": "string"},
    "pretrained": {"type": "string"},
    "seed": {"type": "integer", "minimum": 0},
    "metrics_file": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
