{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Yangjunjie-Lin/recoalign/main/schemas/run.schema.json",
  "title": "ReCoAlign run record",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "status",
    "started_at",
    "completed_at",
    "config_path",
    "config_sha256",
    "git_commit",
    "dataset",
    "dataset_split",
    "dataset_manifest_path",
    "dataset_manifest_sha256",
    "dataset_verification",
    "model",
    "pretrained",
    "checkpoint_manifest_path",
    "checkpoint_manifest_sha256",
    "checkpoint_verification",
    "seed",
    "precision",
    "metrics_file",
    "notes",
    "review"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["pilot", "partial", "failed", "complete", "reportable"]},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": ["string", "null"], "format": "date-time"},
    "config_path": {"type": ["string", "null"]},
    "config_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "git_commit": {"type": ["string", "null"]},
    "dataset": {"type": "string", "minLength": 1},
    "dataset_split": {"type": "string", "minLength": 1},
    "dataset_manifest_path": {"type": "string", "minLength": 1},
    "dataset_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "dataset_verification": {
      "type": "object",
      "required": ["status", "declared_files", "failures"],
      "properties": {
        "status": {"enum": ["passed", "failed", "not_run"]},
        "declared_files": {"type": "integer", "minimum": 0},
        "failures": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "model": {"type": "string", "minLength": 1},
    "pretrained": {"type": "string", "minLength": 1},
    "checkpoint": {"type": ["string", "null"]},
    "checkpoint_manifest_path": {"type": "string", "minLength": 1},
    "checkpoint_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "checkpoint_verification": {
      "type": "object",
      "required": ["status", "declared_files", "failures"],
      "properties": {
        "status": {"enum": ["passed", "failed", "not_run"]},
        "declared_files": {"type": "integer", "minimum": 0},
        "failures": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "seed": {"type": "integer", "minimum": 0},
    "precision": {"type": ["string", "null"]},
    "metrics_file": {"type": ["string", "null"]},
    "notes": {"type": ["string", "null"]},
    "review": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["reviewed_by", "reviewed_at", "decision", "notes"],
          "properties": {
            "reviewed_by": {"type": "string", "minLength": 1},
            "reviewed_at": {"type": "string", "format": "date-time"},
            "decision": {"const": "reportable"},
            "notes": {"type": ["string", "null"]},
            "verification_run_id": {"type": "string", "minLength": 1},
            "promotion_evidence_file": {"type": "string", "minLength": 1},
            "promotion_evidence_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "comparison_file": {"type": "string", "minLength": 1},
            "comparison_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "prediction_review_file": {"type": "string", "minLength": 1},
            "prediction_review_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "prediction_review_count": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "dataset": {"const": "winoground"},
          "status": {"const": "reportable"}
        },
        "required": ["dataset", "status"]
      },
      "then": {
        "properties": {
          "review": {
            "type": "object",
            "required": [
              "verification_run_id",
              "promotion_evidence_file",
              "promotion_evidence_sha256",
              "comparison_file",
              "comparison_sha256",
              "prediction_review_file",
              "prediction_review_sha256",
              "prediction_review_count"
            ],
            "properties": {
              "prediction_review_count": {"const": 400}
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
